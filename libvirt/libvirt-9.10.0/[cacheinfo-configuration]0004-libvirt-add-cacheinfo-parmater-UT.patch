+XDG_CONFIG_HOME=/var/lib/libvirt/qemu/domain--1-foo/.config \
+/usr/bin/qemu-system-x86_64 \
+-name guest=foo,debug-threads=on \
+-S \
+-object '{"qom-type":"secret","id":"masterKey0","format":"raw","file":"/var/lib/libvirt/qemu/domain--1-foo/master-key.aes"}' \
+-machine pc,usb=off,dump-guest-core=off,memory-backend=pc.ram,acpi=off,smp-cache.0.name=l1i,smp-cache.0.location=core,smp-cache.0.size=131072,smp-cache.0.sets=512,smp-cache.0.associativity=4,smp-cache.0.line=64,smp-cache.1.name=l1d,smp-cache.1.location=core,smp-cache.1.size=65536,smp-cache.1.sets=256,smp-cache.1.associativity=4,smp-cache.1.line=64,smp-cache.2.name=l2,smp-cache.2.location=core,smp-cache.2.size=1048576,smp-cache.2.sets=2048,smp-cache.2.associativity=8,smp-cache.2.line=64,smp-cache.3.name=l3,smp-cache.3.location=cluster,smp-cache.3.size=23855104,smp-cache.3.sets=16384,smp-cache.3.associativity=19,smp-cache.3.line=64 \
