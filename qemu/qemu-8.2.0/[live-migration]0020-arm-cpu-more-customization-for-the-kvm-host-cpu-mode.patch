+static void aarch64_kunpeng_920_initfn(Object *obj)
+{
+    ARMCPU *cpu = ARM_CPU(obj);
+    ARMISARegisters *isar = &cpu->isar;
+    /*
+     * Hisilicon Kunpeng-920 CPU is similar to cortex-a72,
+     * so first initialize cpu data as cortex-a72,
+     * and then update the special register.
+     */
+    aarch64_host_initfn(obj);
+
+    cpu->midr = 0x480fd010;
+    cpu->ctr = 0x84448004;
+    cpu->isar.mvfr0 = 0x0;
+    cpu->isar.mvfr1 = 0x0;
+    cpu->isar.mvfr2 = 0x0;
+    SET_IDREG(isar, ID_MMFR0, 0x0);
+    SET_IDREG(isar, ID_MMFR1, 0x0);
+    SET_IDREG(isar, ID_MMFR2, 0x0);
+    SET_IDREG(isar, ID_MMFR3, 0x0);
+    SET_IDREG(isar, ID_MMFR4, 0x0);
+    SET_IDREG(isar, ID_ISAR0, 0x0);
+    SET_IDREG(isar, ID_ISAR1, 0x0);
+    SET_IDREG(isar, ID_ISAR2, 0x0);
+    SET_IDREG(isar, ID_ISAR3, 0x0);
+    SET_IDREG(isar, ID_ISAR4, 0x0);
+    SET_IDREG(isar, ID_ISAR5, 0x0);
+    SET_IDREG(isar, ID_PFR0, 0x0);
+    SET_IDREG(isar, ID_PFR1, 0x0);
+    SET_IDREG(isar, ID_DFR0, 0x0);
+    SET_IDREG(isar, ID_AA64PFR0, 0x1100000011111111);
+    SET_IDREG(isar, ID_AA64PFR1, 0x20);
+    SET_IDREG(isar, ID_AA64DFR0, 0xf010305408);
+    SET_IDREG(isar, ID_AA64DFR1, 0x0);
+    SET_IDREG(isar, ID_AA64ISAR0, 0x1100010211120);
+    SET_IDREG(isar, ID_AA64ISAR1, 0x11001);
+    SET_IDREG(isar, ID_AA64ISAR2, 0x0);
+    SET_IDREG(isar, ID_AA64MMFR0, 0x101025);
+    SET_IDREG(isar, ID_AA64MMFR1, 0x10211122);
+    SET_IDREG(isar, ID_AA64MMFR2, 0x11);
+    SET_IDREG(isar, ID_AA64MMFR3, 0x0);
+    SET_IDREG(isar, ID_AA64ZFR0, 0x0);
+}
