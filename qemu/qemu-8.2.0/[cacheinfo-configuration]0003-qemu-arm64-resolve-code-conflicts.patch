+struct cache_level_info {
+    struct cache_level_info* next;
+    uint32_t offset;
+    int level;
+    const char* level_name;
+};
+
+static struct cache_level_info* __make_cache_if_enable(GArray *table_data, uint32_t pptt_start, MachineState *ms, CacheBindProcessHierarchy bind, uint32_t *id)
+{
+    DECLARE_BITMAP(bind_mask, CACHE_BIND_PROCESS_HIERARCHY__MAX);
+    bitmap_zero(bind_mask, CACHE_BIND_PROCESS_HIERARCHY__MAX);
+
+    /*
+     * cache_level_info记录offset和level，
+     * 插入有顺序要求按照level从小到大排序
+     * 构建process数据时只从前面抽取最高level的offset
+     * offset为相对于pptt_start开始offset
+     */
+    struct cache_level_info* head = NULL;
+
+    for (int i = 0; i < CACHE_LEVEL_AND_TYPE__MAX; i++) {
+        if (ms->smp_cache.props[i].location == bind && ms->smp_cache.props[i].size > 0) {
+            set_bit(i, bind_mask);
+
+            struct cache_level_info* node = malloc(sizeof(struct cache_level_info));
+            node->offset = table_data->len - pptt_start;
+            
+            node->level_name = CacheLevelAndType_str(ms->smp_cache.props[i].name);
+            node->level = atoi(node->level_name + 1); // level_name格式为L1D/L1I/L2/L3等，直接取数字部分
+            node->next = NULL;
+
+            if (head == NULL) {
+                head = node;
+            } else {
+                struct cache_level_info* prev = NULL;
+                struct cache_level_info* curr = head;
+
+                while (curr && curr->level < node->level) {
+                    prev = curr;
+                    curr = curr->next;
+                }
+
+                if (prev == NULL) {
+                    node->next = head;
+                    head = node;
+                } else {
+                    prev->next = node;
+                    node->next = curr;
+                }
+            }
+
+            uint8_t attributes = ((node->level_name[1] == '3') ? 0x2 : 0x0) | // L3 indicates Read and Write Allocate
+                                 ((node->level_name[2] == 'i') ? 0x1 << 2 : 0x0) | // if instruction cache
+                                 ((node->level_name[2] == '\0') ? 0x2 << 2 : 0x0); // if unified cache
+
+            build_cache_hierarchy_node(table_data,
+                                       0xff, /* Flags */
+                                       0, /* Next Level of Cache, to be updated by Guest linker at runtime */
+                                       ms->smp_cache.props[i].size,
+                                       ms->smp_cache.props[i].sets,
+                                       ms->smp_cache.props[i].associativity,
+                                       attributes, /* Attributes */
+                                       ms->smp_cache.props[i].line,
+                                       id);
+        }
+    }
+
+    // 检查一遍设置next_level
+    struct cache_level_info* curr = head;
+    while (curr) {
+        struct cache_level_info* next = curr->next;
+        while (next) {
+            if (next->level == curr->level + 1) {
+                if (next->level_name[2] == curr->level_name[2] || next->level_name[2] == '\0') { 
+                    *(uint32_t*)(table_data->data + pptt_start + curr->offset + 8) = next->offset; // next_level offset
+                    break;
+                }
+            }
+            next = next->next;
+        }
+        curr = curr->next;
+            
+    }
+    
+    return head;
+}
+
+static int make_cache_if_enable(GArray *table_data, uint32_t pptt_start, MachineState *ms, CacheBindProcessHierarchy bind, uint32_t *cache_buf, uint32_t *id)
+{
+    struct cache_level_info* head = __make_cache_if_enable(table_data, pptt_start, ms, bind, id);
+    struct cache_level_info* curr = head;
+    int cache_count = 0;
+    while (curr) {
+        struct cache_level_info* next = curr->next;
+        cache_buf[cache_count++] = curr->offset;
+        int level = curr->level;
+        free(curr);
+        if (next != NULL && next->level != level) {
+            curr = next;
+            break;
+        }
+        curr = next;
     }
+    while (curr) {
+        struct cache_level_info* next = curr->next;
+        free(curr);
+        curr = next;
+    }
+    return cache_count;
 }
 
