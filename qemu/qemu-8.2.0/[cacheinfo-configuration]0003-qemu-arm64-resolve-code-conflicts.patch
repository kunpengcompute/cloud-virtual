+static uint64_t virt_get_vcpu_clidr(MachineState *ms)
+{
+    int loc = 0;
+    uint64_t reg = 0;
+    /* Find out how many cache levels there are */
+    DECLARE_BITMAP(level_mask, 8); /* clidr supports up to 8 cache levels */
+    bitmap_zero(level_mask, 8);
+    for (int i = 0; i < CACHE_LEVEL_AND_TYPE__MAX; i++) {
+        const char* name = CacheLevelAndType_str(ms->smp_cache.props[i].name);
+        uint32_t level = atoi(name + 1); /* name format is L1, L2, L3... */
+        if (ms->smp_cache.props[i].size == 0) {
+            continue;
+        }
+
+        if (!test_bit(level, level_mask)) {
+            set_bit(level, level_mask);
+            ++loc;
+        }
+
+        if (name[2] == 'i') {
+            reg |= CTYPE_INS << CLIDR_CTYPE_SHIFT(level); /* instruction cache */
+        } else if (name[2] == 'd') {
+            reg |= CTYPE_DATA << CLIDR_CTYPE_SHIFT(level); /* data cache */
+        } else {
+            reg |= CTYPE_UNIFIED << CLIDR_CTYPE_SHIFT(level); /* unified cache */
+        }
+    }
+
+    reg |= loc << CLIDR_LOC_SHIFT;
+    return reg;
+}
+
