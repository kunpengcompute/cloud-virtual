From 3b3d223b1e23b36dfbe02f28b86399640dd618d2 Mon Sep 17 00:00:00 2001
From: lixuyuan4 <lixuyuan4@huawei.com>
Date: Wed, 20 May 2026 09:41:49 +0800
Subject: [PATCH 12/12] qemu: arm64: move CLIDR injection after
 kvm_arm_writable_idregs_to_cpreg_list to prevent overwrite

---
 target/arm/kvm64.c | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/target/arm/kvm64.c b/target/arm/kvm64.c
index 4839488047..d2bda9b325 100644
--- a/target/arm/kvm64.c
+++ b/target/arm/kvm64.c
@@ -968,6 +968,12 @@ int kvm_arch_init_vcpu(CPUState *cs)
         return ret;
     }
 
+    if (cpu->kvm_rme || virtcca_cvm_enabled()) {
+        return 0;
+    }
+    /* overwrite writable ID regs with their updated property values */
+    kvm_arm_writable_idregs_to_cpreg_list(cpu);
+
     /* Inject CLIDR register from smp-cache configuration into cpreg array */
     if (cs->clidr_reg) {
         for (int i = 0; i < cpu->cpreg_array_len; i++) {
@@ -978,12 +984,6 @@ int kvm_arch_init_vcpu(CPUState *cs)
         }
     }
 
-    if (cpu->kvm_rme || virtcca_cvm_enabled()) {
-        return 0;
-    }
-    /* overwrite writable ID regs with their updated property values */
-    kvm_arm_writable_idregs_to_cpreg_list(cpu);
-
     write_list_to_kvmstate(cpu, 3);
 
     return 0;
-- 
2.34.1

