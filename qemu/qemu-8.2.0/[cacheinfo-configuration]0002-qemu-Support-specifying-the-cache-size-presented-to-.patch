         build_append_int_noprefix(tbl, ARM_L1CACHE_LINE_SIZE, 2);
         break;
     case ARM_L2_CACHE: /* L2 cache info */
-        build_append_int_noprefix(tbl, ARM_L2CACHE_SIZE, 4);
+        cache_size = machine_get_cache_size(ms, CACHE_LEVEL_AND_TYPE_L2);
