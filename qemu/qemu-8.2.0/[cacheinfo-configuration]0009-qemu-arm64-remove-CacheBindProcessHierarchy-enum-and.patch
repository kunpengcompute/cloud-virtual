         .cache_id = 0,
     };
-    uint32_t cache_buf[CACHE_BIND_PROCESS_HIERARCHY__MAX];
+    uint32_t cache_buf[CPU_TOPOLOGY_LEVEL__MAX];
     int cache_count;
 
     /*
@@ -282,7 +282,7 @@ static void build_pptt_arm(GArray *table_data, BIOSLinker *linker, MachineState
             socket_id = cpus->cpus[n].props.socket_id;
             cluster_id = -1;
             core_id = -1;
-            cache_count = make_cache_if_enable(&ctx, CACHE_BIND_PROCESS_HIERARCHY_SOCKET, cache_buf);
+            cache_count = make_cache_if_enable(&ctx, CPU_TOPOLOGY_LEVEL_SOCKET, cache_buf);
             socket_offset = table_data->len - pptt_start;
             build_processor_hierarchy_node(table_data,
                 (1 << 0), /* Physical package */
@@ -293,7 +293,7 @@ static void build_pptt_arm(GArray *table_data, BIOSLinker *linker, MachineState
             if (cpus->cpus[n].props.cluster_id != cluster_id) {
                 cluster_id = cpus->cpus[n].props.cluster_id;
                 core_id = -1;
-                cache_count = make_cache_if_enable(&ctx, CACHE_BIND_PROCESS_HIERARCHY_CLUSTER, cache_buf);
+                cache_count = make_cache_if_enable(&ctx, CPU_TOPOLOGY_LEVEL_CLUSTER, cache_buf);
                 cluster_offset = table_data->len - pptt_start;
                 build_processor_hierarchy_node(table_data,
                     (0 << 0), /* Not a physical package */
@@ -303,7 +303,7 @@ static void build_pptt_arm(GArray *table_data, BIOSLinker *linker, MachineState
             cluster_offset = socket_offset;
         }
 
-        cache_count = make_cache_if_enable(&ctx, CACHE_BIND_PROCESS_HIERARCHY_CORE, cache_buf);
+        cache_count = make_cache_if_enable(&ctx, CPU_TOPOLOGY_LEVEL_CORE, cache_buf);
         if (ms->smp.threads == 1) {
             build_processor_hierarchy_node(table_data,
                 (1 << 1) | /* ACPI Processor ID valid */
@@ -318,7 +318,7 @@ static void build_pptt_arm(GArray *table_data, BIOSLinker *linker, MachineState
                     cluster_offset, core_id, cache_buf, cache_count);
             }
 
-            cache_count = make_cache_if_enable(&ctx, CACHE_BIND_PROCESS_HIERARCHY_THREAD, cache_buf);
+            cache_count = make_cache_if_enable(&ctx, CPU_TOPOLOGY_LEVEL_THREAD, cache_buf);
             build_processor_hierarchy_node(table_data,
                 (1 << 1) | /* ACPI Processor ID valid */
                 (1 << 2) | /* Processor is a Thread */
