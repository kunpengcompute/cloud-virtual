 {
-    DECLARE_BITMAP(bind_mask, CACHE_BIND_PROCESS_HIERARCHY__MAX);
-    bitmap_zero(bind_mask, CACHE_BIND_PROCESS_HIERARCHY__MAX);
+    DECLARE_BITMAP(bind_mask, CPU_TOPOLOGY_LEVEL__MAX);
+    bitmap_zero(bind_mask, CPU_TOPOLOGY_LEVEL__MAX);
 
     /*
      * cache_level_info记录offset和level，
@@ -186,7 +186,7 @@ static struct cache_level_info* make_cache_if_enable_internal(struct PpttBuildCt
     struct cache_level_info* head = NULL;
 
     for (int i = 0; i < CACHE_LEVEL_AND_TYPE__MAX; i++) {
-        if (ctx->ms->smp_cache.props[i].location == bind && ctx->ms->smp_cache.props[i].size > 0) {
+        if (ctx->ms->smp_cache.props[i].topology == bind && ctx->ms->smp_cache.props[i].size > 0) {
             set_bit(i, bind_mask);
 
             struct cache_level_info* node = malloc(sizeof(struct cache_level_info));
@@ -220,7 +220,7 @@ static struct cache_level_info* make_cache_if_enable_internal(struct PpttBuildCt
     return head;
 }
 
-static int make_cache_if_enable(struct PpttBuildCtx *ctx, CacheBindProcessHierarchy bind, uint32_t *cache_buf)
+static int make_cache_if_enable(struct PpttBuildCtx *ctx, CpuTopologyLevel bind, uint32_t *cache_buf)
