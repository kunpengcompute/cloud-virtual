 qapi/machine-common.json    | 10 -------
 tests/unit/test-smp-cache.c | 55 ++++++++++++++++++-------------------
 5 files changed, 37 insertions(+), 50 deletions(-)

diff --git a/hw/arm/virt-acpi-build.c b/hw/arm/virt-acpi-build.c
index 326e6935cd..2f1c9ef3b8 100644
--- a/hw/arm/virt-acpi-build.c
+++ b/hw/arm/virt-acpi-build.c
@@ -172,10 +172,10 @@ struct PpttBuildCtx {
     uint32_t cache_id;
 };
 
-static struct cache_level_info* make_cache_if_enable_internal(struct PpttBuildCtx *ctx, CacheBindProcessHierarchy bind)
