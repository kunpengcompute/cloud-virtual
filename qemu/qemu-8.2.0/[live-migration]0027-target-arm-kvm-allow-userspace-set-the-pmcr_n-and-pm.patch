+static void kvm_arm_pmu_set_event_filter_attr(CPUState *cs, uint64_t bmap, uint32_t base)
+{
+    struct kvm_pmu_event_filter event_filter;
+    event_filter.action = KVM_PMU_EVENT_DENY;
+    event_filter.nevents = 0;
+    struct kvm_device_attr attr;
+    attr.group = KVM_ARM_VCPU_PMU_V3_CTRL;
+    attr.attr = KVM_ARM_VCPU_PMU_V3_FILTER;
+    attr.addr = (uintptr_t)&event_filter;
+    uint32_t index = 0;
+    while (bmap > 0) {
+        while ((bmap & 1) == 0) {
+            bmap >>= 1;
+            index++;
+        }
+        event_filter.base_event = index + base;
+        while ((bmap & 1) == 1) {
+            bmap >>= 1;
+            index++;
+            event_filter.nevents++;
+        }
+        if (event_filter.nevents > 0) {
+            if (!kvm_arm_set_device_attr(cs, &attr, "PMU")) {
+                error_report("failed to set PMU event filter");
+                abort();
+            }
+            event_filter.nevents = 0;
+        }
+    }
+}
