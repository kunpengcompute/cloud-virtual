+static void event_info_init(VirtMachineState *vms)
+{
+    for (int i = 0; i < ARM_PMU_PMCEID_NUM; i++) {
+        vms->event_info.bmap[i] = 0UL;
+    }
+
+    for (int i = 0; i < ARM_PMU_EVENT_MAX_NUM; i++) {
+        vms->event_info.events[i] = PMU_EVENT_TYPE_MAX;
+    }
+}
+
+static uint32_t get_event_type_id(PmuEvent event)
+{
+    if (event < PMU_EVENT_SAMPLE_POP) {
+        return event;
+    }
+
+    switch (event)
+    {
+    case PMU_EVENT_L2D_CACHE_LMISS_RD:
+    case PMU_EVENT_L2I_CACHE_LMISS:
+    case PMU_EVENT_L3D_CACHE_LMISS_RD:
+    case PMU_EVENT_TRB_WRAP:
+        return event - PMU_EVENT_L2D_CACHE_LMISS_RD + ARMV8_PMUV3_PERFCTR_L2D_CACHE_LMISS_RD;
+    case PMU_EVENT_TRB_TRIG:
+        return ARMV8_PMUV3_PERFCTR_TRB_TRIG;
+    case PMU_EVENT_TRCEXTOUT0:
+    case PMU_EVENT_TRCEXTOUT1:
+    case PMU_EVENT_TRCEXTOUT2:
+    case PMU_EVENT_TRCEXTOUT3:
+        return event - PMU_EVENT_TRCEXTOUT0 + ARMV8_PMUV3_PERFCTR_TRCEXTOUT0;
+    case PMU_EVENT_CTI_TRIGOUT4:
+    case PMU_EVENT_CTI_TRIGOUT5:
+    case PMU_EVENT_CTI_TRIGOUT6:
+    case PMU_EVENT_CTI_TRIGOUT7:
+        return event - PMU_EVENT_CTI_TRIGOUT4 + ARMV8_PMUV3_PERFCTR_CTI_TRIGOUT4;
+    case PMU_EVENT_LDST_ALIGN_LAT:
+    case PMU_EVENT_LD_ALIGN_LAT:
+    case PMU_EVENT_ST_ALIGN_LAT:
+        return event - PMU_EVENT_LDST_ALIGN_LAT + ARMV8_PMUV3_PERFCTR_LDST_ALIGN_LAT;
+    case PMU_EVENT_MEM_ACCESS_CHECKED:
+    case PMU_EVENT_MEM_ACCESS_CHECKED_RD:
+    case PMU_EVENT_MEM_ACCESS_CHECKED_WR:
+        return event - PMU_EVENT_MEM_ACCESS_CHECKED + ARMV8_MTE_PERFCTR_MEM_ACCESS_CHECKED;
+    default:
+        return event - PMU_EVENT_SAMPLE_POP + ARMV8_SPE_PERFCTR_SAMPLE_POP;
+    }
+}
+
+void parse_denied_events(VirtMachineState *vms, const PmuEventList *events,
+                        Error **errp)
+{
+    const PmuEventList *node;
+    int i = 0;
+    for (node = events; node; node = node->next) {
+        vms->event_info.events[i] = node->value;
+        uint32_t type_id = get_event_type_id(node->value);
+
+        if (type_id < ARMV8_SPE_PERFCTR_SAMPLE_POP) {
+            vms->event_info.bmap[0] |= (1UL << type_id);
+        }else {
+            vms->event_info.bmap[1] |= (1UL << (type_id - ARMV8_SPE_PERFCTR_SAMPLE_POP));
+        }
+        i++;
+    }
+}
+
 static bool virt_get_secure(Object *obj, Error **errp)
 {
     VirtMachineState *vms = VIRT_MACHINE(obj);
@@ -3197,6 +3266,60 @@ static void virt_set_gic_version(Object *obj, const char *value, Error **errp)
     }
 }
 
+static char *virt_get_pmcr_n(Object *obj, Error **errp)
+{
+    VirtMachineState *vms = VIRT_MACHINE(obj);
+    QNum *qn;
+    qn = qnum_from_int(vms->pmcr_n);
+    const char *val = qnum_to_string(qn);
+    return g_strdup(val);
+}
+
+static void virt_set_pmcr_n(Object *obj, const char *value, Error **errp)
+{
+    VirtMachineState *vms = VIRT_MACHINE(obj);
+    int result, err;
+    err = qemu_strtoi(value, NULL, 10, &result);
+    if (err < 0 || result < 1 || result > 31) {
+        error_setg(errp, "Invalid pmcr_n value");
+        error_append_hint(errp, "Valid value is a integer, between 1 and 31.\n");
+        return;
+    }
+    vms->pmcr_n = result;
+}
+
+static void virt_get_event_type(Object *obj, Visitor *v, const char *name,
+                                void *opaque, Error **errp)
+{
+    VirtMachineState *vms = VIRT_MACHINE(obj);
+    PmuEvent *events = vms->event_info.events;
+    PmuEventList *head = NULL;
+    PmuEventList **tail = &head;
+
+    for (int i = 0;i < ARM_PMU_EVENT_MAX_NUM && events[i] != PMU_EVENT_TYPE_MAX; i++) {
+        PmuEvent node = events[i];
+        QAPI_LIST_APPEND(tail, node);
+    }
+
+    visit_type_PmuEventList(v, name, &head, errp);
+    qapi_free_PmuEventList(head);
+}
+
+static void virt_set_event_type(Object *obj, Visitor *v, const char *name,
+                                void *opaque, Error **errp)
+{
+    VirtMachineState *vms = VIRT_MACHINE(obj);
+    PmuEventList *events;
+
+    if (!visit_type_PmuEventList(v, name, &events, errp)) {
+        return;
+    }
+
+    event_info_init(vms);
+    parse_denied_events(vms, events, errp);
+    qapi_free_PmuEventList(events);
+}
+
 static char *virt_get_iommu(Object *obj, Error **errp)
 {
     VirtMachineState *vms = VIRT_MACHINE(obj);
@@ -4077,6 +4200,17 @@ static void virt_machine_class_init(ObjectClass *oc, void *data)
                                           "Describe target cpu impl in the format midr1:revidr1-midr2:revidr2"
                                           "Maximum 4 midr:revidr pair is supported");
 
+    object_class_property_add_str(oc, "pmcr-n", virt_get_pmcr_n,
+                                  virt_set_pmcr_n);
+    object_class_property_set_description(oc, "pmcr-n",
+                                          "Set the number of PMU counter. "
+                                          "Valid value is a integer, between 1 and 31.");
+
+    object_class_property_add(oc, "denied-events-type", "PmuEventWrapper",
+                              virt_get_event_type, virt_set_event_type,
+                              NULL, NULL);
+    object_class_property_set_description(oc, "denied-events-type",
+                                          "closed PMU event list");
 }
 
 static char *virt_get_kvm_type(Object *obj, Error **errp G_GNUC_UNUSED)
