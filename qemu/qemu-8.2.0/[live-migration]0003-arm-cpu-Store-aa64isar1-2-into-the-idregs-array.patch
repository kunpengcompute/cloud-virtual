     cpu->isar.id_aa64mmfr2 = 0x1221011112101011ull;
@@ -1132,7 +1132,7 @@ void aarch64_max_tcg_initfn(Object *obj)
     t = FIELD_DP64(t, ID_AA64ISAR0, RNDR, 1);     /* FEAT_RNG */
     SET_IDREG(isar, ID_AA64ISAR0, t);
 
