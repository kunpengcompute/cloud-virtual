From 73ef54d83149b5ce1b97efeca87ab394ccabd213 Mon Sep 17 00:00:00 2001
From: lixuyuan4 <lixuyuan4@huawei.com>
Date: Tue, 19 May 2026 17:14:28 +0800
Subject: [PATCH 11/12] qemu: arm64: fix CLIDR injection: write to cpreg_values
 instead of kvm_set_one_reg to survive KVM vCPU reset

---
 target/arm/kvm64.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/target/arm/kvm64.c b/target/arm/kvm64.c
index 0f6176d38b..4839488047 100644
--- a/target/arm/kvm64.c
+++ b/target/arm/kvm64.c
@@ -968,6 +968,16 @@ int kvm_arch_init_vcpu(CPUState *cs)
         return ret;
     }
 
+    /* Inject CLIDR register from smp-cache configuration into cpreg array */
+    if (cs->clidr_reg) {
+        for (int i = 0; i < cpu->cpreg_array_len; i++) {
+            if (cpu->cpreg_indexes[i] == ARM64_SYS_REG(ARM_CPU_ID_CLIDR)) {
+                cpu->cpreg_values[i] = cs->clidr_reg;
+                break;
+            }
+        }
+    }
+
     if (cpu->kvm_rme || virtcca_cvm_enabled()) {
         return 0;
     }
-- 
