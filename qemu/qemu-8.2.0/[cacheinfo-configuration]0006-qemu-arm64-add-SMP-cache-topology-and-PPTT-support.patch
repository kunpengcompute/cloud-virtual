-static struct cache_level_info* __make_cache_if_enable(GArray *table_data, uint32_t pptt_start, MachineState *ms, CacheBindProcessHierarchy bind, uint32_t *id)
+/*
+ * Patch the Next Level of Cache field for each cache node in the linked list.
+ * Finds the next node with level+1 and matching cache type, then writes its offset.
+ */
+static void update_cache_next_level(struct cache_level_info *head,
+                                    GArray *table_data, uint32_t pptt_start)
+{
+    struct cache_level_info *curr = head;
+    while (curr) {
+        struct cache_level_info *next = curr->next;
+        while (next) {
+            bool level_match = next->level == curr->level + 1;
+            bool type_match = next->level_name[CACHE_TYPE_SUFFIX_INDEX] == curr->level_name[CACHE_TYPE_SUFFIX_INDEX] ||
+                              next->level_name[CACHE_TYPE_SUFFIX_INDEX] == '\0';
+            if (level_match && type_match) {
+                *(uint32_t *)(table_data->data + pptt_start +
+                              curr->offset + PPTT_CACHE_NEXT_LEVEL_OFFSET) = next->offset;
+                break;
+            }
+            next = next->next;
+        }
+        curr = curr->next;
+    }
+}
+
+/*
+ * Insert a cache_level_info node into a sorted linked list by level (ascending).
+ * Returns the new head of the list.
+ */
+static struct cache_level_info *cache_level_info_insert(struct cache_level_info *head,
+                                                         struct cache_level_info *node)
+{
+    struct cache_level_info *prev = NULL;
+    struct cache_level_info *curr = head;
+
+    while (curr && curr->level < node->level) {
+        prev = curr;
+        curr = curr->next;
+    }
+
+    node->next = curr;
+    if (prev == NULL) {
+        return node;
+    }
+    prev->next = node;
+    return head;
+}
