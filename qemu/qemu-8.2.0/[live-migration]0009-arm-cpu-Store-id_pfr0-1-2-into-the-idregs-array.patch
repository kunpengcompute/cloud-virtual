         FIELD_DP64_IDREG(isar, ID_AA64PFR0, EL3, 0);
 
@@ -2202,8 +2202,7 @@ static void arm_cpu_realizefn(DeviceState *dev, Error **errp)
          * registers if we don't have EL2.
          */
         FIELD_DP64_IDREG(isar, ID_AA64PFR0, EL2, 0);
