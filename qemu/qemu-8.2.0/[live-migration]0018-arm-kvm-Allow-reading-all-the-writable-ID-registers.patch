-bool kvm_arm_get_host_cpu_features(ARMHostCPUFeatures *ahcf);
+bool kvm_arm_get_host_cpu_features(ARMCPU *cpu, ARMHostCPUFeatures *ahcf,
+                                   bool exhaustive);
 
