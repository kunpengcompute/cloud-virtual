From 415e243a2422df6df78dc87ac3b51354b3d52509 Mon Sep 17 00:00:00 2001
From: lutong <lutong14@huawei.com>
Date: Mon, 25 May 2026 11:53:19 +0800
Subject: [PATCH] zram: zram switch to async acomp and mutex

Currently, the zram read path is synchronous, holding the zram_slot_lock
for the entire duration of the page decompression and read process. This
patch converts the synchronous interface into an asynchronous one,
releasing the zram_slot_lock early when reading and decompressing pages.

However, releasing the slot lock early introduces potential concurrency
hazards (e.g., race conditions) if the slot is modified by other
concurrent operations. Therefore, this optimization is conditionally
applicable and requires a restricted operational environment.

To safely use this asynchronous read path and avoid concurrency issues,
the following kernel configurations MUST be disabled:

  - CONFIG_ZRAM_WRITEBACK
  - CONFIG_ZRAM_MULTI_COMP
  - CONFIG_ZRAM_MEMORY_TRACKING

In addition, the zram swap device must be activated without the discard
option. The expected usage is:
  mkswap /dev/zram0
  swapon -p 100 /dev/zram0

Using NAME     TYPE      SIZE   USED PRIO
/dev/sdc partition   2G 623.2M   -2 (discard) or enabling the aforementioned kernel configs
will lead to race conditions and must be avoided when using this patch.

Signed-off-by: wangyi <wangyi395@huawei.com>
---
 drivers/block/zram/zcomp.c    | 89 ++++++++++++++++++++++++++---------
 drivers/block/zram/zcomp.h    | 12 +++--
 drivers/block/zram/zram_drv.c | 73 ++++++++++++++++------------
 3 files changed, 119 insertions(+), 55 deletions(-)

diff --git a/drivers/block/zram/zcomp.c b/drivers/block/zram/zcomp.c
index 55af4efd7983..06e04fc67e4b 100644
--- a/drivers/block/zram/zcomp.c
+++ b/drivers/block/zram/zcomp.c
@@ -11,6 +11,10 @@
 #include <linux/sched.h>
 #include <linux/cpu.h>
 #include <linux/crypto.h>
+#include <linux/mutex.h>
+#include <linux/topology.h>
+#include <crypto/acompress.h>
+#include <linux/scatterlist.h>
 
 #include "zcomp.h"
 
@@ -35,9 +39,12 @@ static const char * const backends[] = {
 
 static void zcomp_strm_free(struct zcomp_strm *zstrm)
 {
+	if (zstrm->req)
+		acomp_request_free(zstrm->req);
 	if (!IS_ERR_OR_NULL(zstrm->tfm))
-		crypto_free_comp(zstrm->tfm);
+		crypto_free_acomp(zstrm->tfm);
 	free_pages((unsigned long)zstrm->buffer, 1);
+	zstrm->req = NULL;
 	zstrm->tfm = NULL;
 	zstrm->buffer = NULL;
 }
@@ -46,15 +53,28 @@ static void zcomp_strm_free(struct zcomp_strm *zstrm)
  * Initialize zcomp_strm structure with ->tfm initialized by backend, and
  * ->buffer. Return a negative value on error.
  */
-static int zcomp_strm_init(struct zcomp_strm *zstrm, struct zcomp *comp)
+static int zcomp_strm_init(struct zcomp_strm *zstrm, struct zcomp *comp, int cpu)
 {
-	zstrm->tfm = crypto_alloc_comp(comp->name, 0, 0);
+	int ret;
+
+	zstrm->tfm = crypto_alloc_acomp_node(comp->name, 0, 0, cpu_to_node(cpu));
+	if (IS_ERR(zstrm->tfm)) {
+		ret = PTR_ERR(zstrm->tfm);
+		zstrm->tfm = NULL;
+		return ret;
+	}
+
+	zstrm->req = acomp_request_alloc(zstrm->tfm);
+	if (!zstrm->req) {
+		zcomp_strm_free(zstrm);
+		return -ENOMEM;
+	}
 	/*
 	 * allocate 2 pages. 1 for compressed data, plus 1 extra for the
 	 * case when compressed size is larger than the original one
 	 */
 	zstrm->buffer = (void *)__get_free_pages(GFP_KERNEL | __GFP_ZERO, 1);
-	if (IS_ERR_OR_NULL(zstrm->tfm) || !zstrm->buffer) {
+	if (!zstrm->buffer) {
 		zcomp_strm_free(zstrm);
 		return -ENOMEM;
 	}
@@ -70,7 +90,7 @@ bool zcomp_available_algorithm(const char *comp)
 	 * This also means that we permit zcomp initialisation
 	 * with any compressing algorithm known to crypto api.
 	 */
-	return crypto_has_comp(comp, 0, 0) == 1;
+	return crypto_has_acomp(comp, 0, 0) == 1;
 }
 
 /* show available compressors */
@@ -95,7 +115,7 @@ ssize_t zcomp_available_show(const char *comp, char *buf)
 	 * Out-of-tree module known to crypto api or a missing
 	 * entry in `backends'.
 	 */
-	if (!known_algorithm && crypto_has_comp(comp, 0, 0) == 1)
+	if (!known_algorithm && crypto_has_acomp(comp, 0, 0) == 1)
 		sz += scnprintf(buf + sz, PAGE_SIZE - sz - 2,
 				"[%s] ", comp);
 
@@ -105,18 +125,35 @@ ssize_t zcomp_available_show(const char *comp, char *buf)
 
 struct zcomp_strm *zcomp_stream_get(struct zcomp *comp)
 {
-	local_lock(&comp->stream->lock);
-	return this_cpu_ptr(comp->stream);
+	struct zcomp_strm *zstrm;
+
+	for (;;) {
+		zstrm = raw_cpu_ptr(comp->stream);
+		mutex_lock(&zstrm->lock);
+		if (likely(zstrm->tfm))
+			return zstrm;
+		mutex_unlock(&zstrm->lock);
+	}
 }
 
-void zcomp_stream_put(struct zcomp *comp)
+void zcomp_stream_put(struct zcomp_strm *zstrm)
 {
-	local_unlock(&comp->stream->lock);
+	mutex_unlock(&zstrm->lock);
 }
 
 int zcomp_compress(struct zcomp_strm *zstrm,
 		const void *src, unsigned int *dst_len)
 {
+	struct scatterlist src_sc, dst_sc;
+	struct crypto_wait wait;
+	int ret;
+
+	crypto_init_wait(&wait);
+	acomp_request_set_callback(zstrm->req, CRYPTO_TFM_REQ_MAY_BACKLOG,
+				  crypto_req_done, &wait);
+
+	sg_init_one(&src_sc, src, PAGE_SIZE);
+	sg_init_one(&dst_sc, zstrm->buffer, PAGE_SIZE * 2);
 	/*
 	 * Our dst memory (zstrm->buffer) is always `2 * PAGE_SIZE' sized
 	 * because sometimes we can endup having a bigger compressed data
@@ -131,21 +168,29 @@ int zcomp_compress(struct zcomp_strm *zstrm,
 	 * the dst buffer, zram_drv will take care of the fact that
 	 * compressed buffer is too big.
 	 */
-	*dst_len = PAGE_SIZE * 2;
-
-	return crypto_comp_compress(zstrm->tfm,
-			src, PAGE_SIZE,
-			zstrm->buffer, dst_len);
+	acomp_request_set_params(zstrm->req, &src_sc, &dst_sc,
+				PAGE_SIZE, PAGE_SIZE * 2);
+	ret = crypto_wait_req(crypto_acomp_compress(zstrm->req), &wait);
+	*dst_len = zstrm->req->dlen;
+	return ret;
 }
 
 int zcomp_decompress(struct zcomp_strm *zstrm,
 		const void *src, unsigned int src_len, void *dst)
 {
-	unsigned int dst_len = PAGE_SIZE;
+	struct scatterlist src_sc, dst_sc;
+	struct crypto_wait wait;
+	int ret;
 
-	return crypto_comp_decompress(zstrm->tfm,
-			src, src_len,
-			dst, &dst_len);
+	crypto_init_wait(&wait);
+	acomp_request_set_callback(zstrm->req, CRYPTO_TFM_REQ_MAY_BACKLOG,
+				  crypto_req_done, &wait);
+	sg_init_one(&src_sc, src, src_len);
+	sg_init_one(&dst_sc, dst, PAGE_SIZE);
+	acomp_request_set_params(zstrm->req, &src_sc, &dst_sc,
+				src_len, PAGE_SIZE);
+	ret = crypto_wait_req(crypto_acomp_decompress(zstrm->req), &wait);
+	return ret;
 }
 
 int zcomp_cpu_up_prepare(unsigned int cpu, struct hlist_node *node)
@@ -155,9 +200,9 @@ int zcomp_cpu_up_prepare(unsigned int cpu, struct hlist_node *node)
 	int ret;
 
 	zstrm = per_cpu_ptr(comp->stream, cpu);
-	local_lock_init(&zstrm->lock);
+	mutex_init(&zstrm->lock);
 
-	ret = zcomp_strm_init(zstrm, comp);
+	ret = zcomp_strm_init(zstrm, comp, cpu);
 	if (ret)
 		pr_err("Can't allocate a compression stream\n");
 	return ret;
@@ -169,7 +214,9 @@ int zcomp_cpu_dead(unsigned int cpu, struct hlist_node *node)
 	struct zcomp_strm *zstrm;
 
 	zstrm = per_cpu_ptr(comp->stream, cpu);
+	mutex_lock(&zstrm->lock);
 	zcomp_strm_free(zstrm);
+	mutex_unlock(&zstrm->lock);
 	return 0;
 }
 
diff --git a/drivers/block/zram/zcomp.h b/drivers/block/zram/zcomp.h
index cdefdef93da8..3a929dba8834 100644
--- a/drivers/block/zram/zcomp.h
+++ b/drivers/block/zram/zcomp.h
@@ -5,14 +5,16 @@
 
 #ifndef _ZCOMP_H_
 #define _ZCOMP_H_
-#include <linux/local_lock.h>
+#include <linux/mutex.h>
+#include <crypto/acompress.h>
 
 struct zcomp_strm {
-	/* The members ->buffer and ->tfm are protected by ->lock. */
-	local_lock_t lock;
+	/* The members ->buffer, ->tfm and ->req are protected by ->lock. */
+	struct mutex lock;
 	/* compression/decompression buffer */
 	void *buffer;
-	struct crypto_comp *tfm;
+	struct crypto_acomp *tfm;
+	struct acomp_req *req;
 };
 
 /* dynamic per-device compression frontend */
@@ -31,7 +33,7 @@ struct zcomp *zcomp_create(const char *alg);
 void zcomp_destroy(struct zcomp *comp);
 
 struct zcomp_strm *zcomp_stream_get(struct zcomp *comp);
-void zcomp_stream_put(struct zcomp *comp);
+void zcomp_stream_put(struct zcomp_strm *zstrm);
 
 int zcomp_compress(struct zcomp_strm *zstrm,
 		const void *src, unsigned int *dst_len);
diff --git a/drivers/block/zram/zram_drv.c b/drivers/block/zram/zram_drv.c
index 8a26614c0b52..7ad78086ee88 100644
--- a/drivers/block/zram/zram_drv.c
+++ b/drivers/block/zram/zram_drv.c
@@ -1315,10 +1315,12 @@ static void zram_free_page(struct zram *zram, size_t index)
 
 /*
  * Reads (decompresses if needed) a page from zspool (zsmalloc).
- * Corresponding ZRAM slot should be locked.
+ * Corresponding ZRAM slot should be locked on entry and is unlocked
+ * on return. tmp buffer is used to copy out compressed data before
+ * releasing the slot lock.
  */
 static int zram_read_from_zspool(struct zram *zram, struct page *page,
-				 u32 index)
+				 u32 index, void *tmp)
 {
 	struct zcomp_strm *zstrm;
 	unsigned long handle;
@@ -1330,48 +1332,59 @@ static int zram_read_from_zspool(struct zram *zram, struct page *page,
 	handle = zram_get_handle(zram, index);
 	if (!handle || zram_test_flag(zram, index, ZRAM_SAME)) {
 		unsigned long value;
-		void *mem;
 
 		value = handle ? zram_get_element(zram, index) : 0;
-		mem = kmap_atomic(page);
-		zram_fill_page(mem, PAGE_SIZE, value);
-		kunmap_atomic(mem);
+		zram_slot_unlock(zram, index);
+
+		dst = kmap_atomic(page);
+		zram_fill_page(dst, PAGE_SIZE, value);
+		kunmap_atomic(dst);
 		return 0;
 	}
 
 	size = zram_get_obj_size(zram, index);
 
-	if (size != PAGE_SIZE) {
-		prio = zram_get_priority(zram, index);
-		zstrm = zcomp_stream_get(zram->comps[prio]);
-	}
-
 	src = zs_map_object(zram->mem_pool, handle, ZS_MM_RO);
 	if (size == PAGE_SIZE) {
 		dst = kmap_atomic(page);
 		memcpy(dst, src, PAGE_SIZE);
 		kunmap_atomic(dst);
-		ret = 0;
-	} else {
-		dst = kmap_atomic(page);
-		ret = zcomp_decompress(zstrm, src, size, dst);
-		kunmap_atomic(dst);
-		zcomp_stream_put(zram->comps[prio]);
+		zs_unmap_object(zram->mem_pool, handle);
+		zram_slot_unlock(zram, index);
+		return 0;
 	}
+
+	prio = zram_get_priority(zram, index);
+	memcpy(tmp, src, size);
 	zs_unmap_object(zram->mem_pool, handle);
+	zram_slot_unlock(zram, index);
+
+	zstrm = zcomp_stream_get(zram->comps[prio]);
+	dst = kmap_atomic(page);
+	ret = zcomp_decompress(zstrm, tmp, size, dst);
+	kunmap_atomic(dst);
+	zcomp_stream_put(zstrm);
 	return ret;
 }
 
 static int zram_read_page(struct zram *zram, struct page *page, u32 index,
 			  struct bio *parent)
 {
+	void *tmp = NULL;
 	int ret;
 
 	zram_slot_lock(zram, index);
 	if (!zram_test_flag(zram, index, ZRAM_WB)) {
-		/* Slot should be locked through out the function call */
-		ret = zram_read_from_zspool(zram, page, index);
-		zram_slot_unlock(zram, index);
+		if (zram_get_handle(zram, index) &&
+		    !zram_test_flag(zram, index, ZRAM_SAME) &&
+		    zram_get_obj_size(zram, index) != PAGE_SIZE) {
+			tmp = (void *)__get_free_page(GFP_NOIO);
+			if (!tmp) {
+				zram_slot_unlock(zram, index);
+				return -ENOMEM;
+			}
+		}
+		ret = zram_read_from_zspool(zram, page, index, tmp);
 	} else {
 		/*
 		 * The slot should be unlocked before reading from the backing
@@ -1382,6 +1395,8 @@ static int zram_read_page(struct zram *zram, struct page *page, u32 index,
 		ret = read_from_bdev(zram, page, zram_get_element(zram, index),
 				     parent);
 	}
+	if (tmp)
+		free_page((unsigned long)tmp);
 
 	/* Should NEVER happen. Return bio error if it does. */
 	if (WARN_ON(ret < 0))
@@ -1445,7 +1460,7 @@ static int zram_write_page(struct zram *zram, struct page *page, u32 index)
 	kunmap_atomic(src);
 
 	if (unlikely(ret)) {
-		zcomp_stream_put(zram->comps[ZRAM_PRIMARY_COMP]);
+		zcomp_stream_put(zstrm);
 		pr_err("Compression failed! err=%d\n", ret);
 		zs_free(zram->mem_pool, handle);
 		return ret;
@@ -1473,7 +1488,7 @@ static int zram_write_page(struct zram *zram, struct page *page, u32 index)
 				__GFP_HIGHMEM |
 				__GFP_MOVABLE);
 	if (IS_ERR_VALUE(handle)) {
-		zcomp_stream_put(zram->comps[ZRAM_PRIMARY_COMP]);
+		zcomp_stream_put(zstrm);
 		atomic64_inc(&zram->stats.writestall);
 		handle = zs_malloc(zram->mem_pool, comp_len,
 				GFP_NOIO | __GFP_HIGHMEM |
@@ -1497,7 +1512,7 @@ static int zram_write_page(struct zram *zram, struct page *page, u32 index)
 	update_used_max(zram, alloced_pages);
 
 	if (zram->limit_pages && alloced_pages > zram->limit_pages) {
-		zcomp_stream_put(zram->comps[ZRAM_PRIMARY_COMP]);
+		zcomp_stream_put(zstrm);
 		zs_free(zram->mem_pool, handle);
 		return -ENOMEM;
 	}
@@ -1511,7 +1526,7 @@ static int zram_write_page(struct zram *zram, struct page *page, u32 index)
 	if (comp_len == PAGE_SIZE)
 		kunmap_atomic(src);
 
-	zcomp_stream_put(zram->comps[ZRAM_PRIMARY_COMP]);
+	zcomp_stream_put(zstrm);
 	zs_unmap_object(zram->mem_pool, handle);
 	atomic64_add(comp_len, &zram->stats.compr_data_size);
 out:
@@ -1604,7 +1619,7 @@ static int zram_recompress(struct zram *zram, u32 index, struct page *page,
 	if (comp_len_old < threshold)
 		return 0;
 
-	ret = zram_read_from_zspool(zram, page, index);
+	ret = zram_read_from_zspool(zram, page, index, NULL);
 	if (ret)
 		return ret;
 
@@ -1638,7 +1653,7 @@ static int zram_recompress(struct zram *zram, u32 index, struct page *page,
 		kunmap_atomic(src);
 
 		if (ret) {
-			zcomp_stream_put(zram->comps[prio]);
+			zcomp_stream_put(zstrm);
 			return ret;
 		}
 
@@ -1648,7 +1663,7 @@ static int zram_recompress(struct zram *zram, u32 index, struct page *page,
 		/* Continue until we make progress */
 		if (class_index_new >= class_index_old ||
 		    (threshold && comp_len_new >= threshold)) {
-			zcomp_stream_put(zram->comps[prio]);
+			zcomp_stream_put(zstrm);
 			continue;
 		}
 
@@ -1697,13 +1712,13 @@ static int zram_recompress(struct zram *zram, u32 index, struct page *page,
 			       __GFP_HIGHMEM |
 			       __GFP_MOVABLE);
 	if (IS_ERR_VALUE(handle_new)) {
-		zcomp_stream_put(zram->comps[prio]);
+		zcomp_stream_put(zstrm);
 		return PTR_ERR((void *)handle_new);
 	}
 
 	dst = zs_map_object(zram->mem_pool, handle_new, ZS_MM_WO);
 	memcpy(dst, zstrm->buffer, comp_len_new);
-	zcomp_stream_put(zram->comps[prio]);
+	zcomp_stream_put(zstrm);
 
 	zs_unmap_object(zram->mem_pool, handle_new);
 
-- 
