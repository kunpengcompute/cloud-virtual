index a437aafa2946..af15705df4a8 100644
--- a/Documentation/admin-guide/kernel-parameters.txt
+++ b/Documentation/admin-guide/kernel-parameters.txt
@@ -1825,6 +1825,26 @@
 			hugepages using the CMA allocator. If enabled, the
 			boot-time allocation of gigantic hugepages is skipped.
 
+	hugetlb_swap=	[KNL] Requires CONFIG_HUGETLB_SWAP enabled.
+			Control whether HugeTLB pages (anonymous and
+			hugetlbfs-backed) may be paged out to a swap
+			device.
+			Format: { on | off (default) }
+
+			on:  enable HugeTLB swap-out.  When the HugeTLB
+			     pool is exhausted, fault-time direct reclaim
+			     will swap idle HugeTLB folios out instead of
+			     failing the allocation.
+			off: disable HugeTLB swap-out.  HugeTLB folios are
+			     never paged out, and pool exhaustion at fault
+			     time delivers SIGBUS as before this feature
+			     existed.
+
+			The parameter only takes effect at boot.  Booting
+			with off after a previous boot with on is safe:
+			any swap entries already on a swap device can
+			still be paged back in.
+
 	hugetlb_free_vmemmap=
 			[KNL] Requires CONFIG_HUGETLB_PAGE_OPTIMIZE_VMEMMAP
 			enabled.
