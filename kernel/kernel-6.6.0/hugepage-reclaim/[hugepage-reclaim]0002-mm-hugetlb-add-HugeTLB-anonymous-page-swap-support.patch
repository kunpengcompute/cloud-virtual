 include/linux/hugetlb.h                       |  14 +
 include/linux/pagemap.h                       |   2 +
 include/linux/swap.h                          |   7 +
 mm/Kconfig                                    |  16 +
 mm/etmem.c                                    |  16 +-
 mm/hugetlb.c                                  | 322 ++++++++++++++++++
 mm/internal.h                                 |  16 +-
 mm/rmap.c                                     |  65 +++-
