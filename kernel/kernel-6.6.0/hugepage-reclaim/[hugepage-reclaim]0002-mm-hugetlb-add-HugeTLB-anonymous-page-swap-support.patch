+#endif /* CONFIG_HUGETLB_SWAP */
+
 void putback_hugetlb_folio(struct folio *folio)
 {
 	folio_putback_active_hugetlb(folio);
@@ -8192,3 +8489,28 @@ struct folio *hugetlb_pool_alloc_size(int nid, unsigned long size)
 }
 EXPORT_SYMBOL_GPL(hugetlb_pool_alloc_size);
 #endif
+
+#ifdef CONFIG_HUGETLB_SWAP
+void hugetlb_inc_swap_pages(struct hstate *h)
+{
+	spin_lock_irq(&hugetlb_lock);
+	h->swap_huge_pages++;
+	spin_unlock_irq(&hugetlb_lock);
+}
+
+void hugetlb_dec_swap_pages(struct hstate *h)
+{
+	spin_lock_irq(&hugetlb_lock);
