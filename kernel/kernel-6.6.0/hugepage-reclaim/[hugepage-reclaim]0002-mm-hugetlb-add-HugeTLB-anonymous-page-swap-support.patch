+#ifdef CONFIG_HUGETLB_SWAP
+/*
+ * Boot-time opt-in for hugetlb swap.  CONFIG_HUGETLB_SWAP only builds the
+ * code in; the cmdline parameter "hugetlb_swap=on" arms it.  Default off so
+ * a kernel built with the feature behaves like a pre-feature kernel until
+ * the operator explicitly opts in.
+ */
