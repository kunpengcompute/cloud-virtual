+#ifdef CONFIG_HUGETLB_SWAP
+/*
+ * Allocate swap slots for a hugetlb folio.  The slot run must be
+ * contiguous, folio-aligned, and fully contained in the swap device.
+ */
+swp_entry_t folio_alloc_swap_huge(struct folio *folio)
+{
+	swp_entry_t entry = {0};
+	struct swap_info_struct *si;
+	unsigned long nr_pages, offset;
+
+	if (WARN_ON_ONCE(!folio_test_hugetlb(folio)))
+		return entry;
+
+	if (!hugetlb_swap_enabled())
+		return entry;
+
+	nr_pages = folio_nr_pages(folio);
+
+	entry = folio_alloc_swap(folio);
+	if (!entry.val)
+		return entry;
+
+	offset = swp_offset(entry);
+	si = swp_swap_info(entry);
+	if (offset + nr_pages > si->max || !IS_ALIGNED(offset, nr_pages)) {
+		pr_err_ratelimited(
+			"hugetlb swap entry misaligned or overflow: offset=%lu nr=%lu max=%u\n",
+			offset, nr_pages, si->max);
+		put_swap_folio(folio, entry);
+		entry.val = 0;
+	}
+
+	return entry;
+}
+#endif /* CONFIG_HUGETLB_SWAP */
