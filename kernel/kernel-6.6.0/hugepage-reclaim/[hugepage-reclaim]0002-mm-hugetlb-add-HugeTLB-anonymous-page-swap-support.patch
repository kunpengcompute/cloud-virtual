+#ifdef CONFIG_HUGETLB_SWAP
+static DECLARE_WAIT_QUEUE_HEAD(swapcache_wq);
+
+static inline bool should_try_to_free_swap(struct folio *folio,
+					struct vm_area_struct *vma, unsigned int flags)
+{
+	if (!folio_test_swapcache(folio))
+		return false;
+	if (mem_cgroup_swap_full(folio) || (vma->vm_flags & VM_LOCKED) ||
+		folio_test_mlocked(folio))
+		return true;
+
+	return (flags & FAULT_FLAG_WRITE) &&
+		folio_ref_count(folio) == (1 + folio_nr_pages(folio));
+}
+
+static vm_fault_t hugetlb_anon_swapin(struct mm_struct *mm,
+			struct vm_area_struct *vma, unsigned long haddr,
+			pte_t *ptep, pte_t old_pte,
+			unsigned int flags, u32 hash)
+{
+	struct swap_info_struct *si = NULL;
+	struct hstate *h = hstate_vma(vma);
+	int nr_pages = pages_per_huge_page(h);
+	swp_entry_t entry = pte_to_swp_entry(old_pte);
+	struct folio *swapcache, *folio = NULL;
+	DECLARE_WAITQUEUE(wait, current);
+	bool need_clear_cache = false;
+	spinlock_t *ptl;
+	pte_t new_pte;
+	vm_fault_t ret = 0;
+
+	/* Prevent swapoff from happening to us */
+	si = get_swap_device(entry);
+	if (unlikely(!si))
+		goto out;
+
+	folio = swap_cache_get_folio(entry, vma, haddr);
+	swapcache = folio;
+	if (likely(!folio)) {
+		folio = alloc_hugetlb_folio(vma, haddr, 1);
+		if (IS_ERR(folio)) {
+			if (hugetlb_pte_stable(h, mm, ptep, old_pte))
+				ret = vmf_error(PTR_ERR(folio));
+			else
+				ret = 0;
+
+			if (ret && PTR_ERR(folio) == -ENOSPC &&
+				(flags & FAULT_FLAG_ALLOW_RETRY) &&
+				!(flags & FAULT_FLAG_RETRY_NOWAIT)) {
+				hugetlb_vma_unlock_read(vma);
+				mutex_unlock(&hugetlb_fault_mutex_table[hash]);
+				put_swap_device(si);
+
+				if (try_hugetlb_reclaim_notify(h, mm, vma, haddr))
+					return VM_FAULT_RETRY;
+				return ret;
+			}
+
+			goto out;
+		}
+
+		__folio_set_locked(folio);
+		nr_pages = folio_nr_pages(folio);
+		if (swapcache_prepare(entry, nr_pages)) {
+			/*
+			 * Relax a bit to prevent rapid
+			 * repeated page faults.
+			 */
+			add_wait_queue(&swapcache_wq, &wait);
+			schedule_timeout_uninterruptible(1);
+			remove_wait_queue(&swapcache_wq, &wait);
+			goto out_page;
+		}
+
+		need_clear_cache = true;
+		__folio_set_swapbacked(folio);
+		folio->swap = entry;
+
+		if (!data_race(si->flags & SWP_SYNCHRONOUS_IO)) {
+			if (add_to_swap_cache(folio, entry, GFP_KERNEL, NULL))
+				goto out_page;
+			swapcache = folio;
+		}
+
+		swap_read_folio(folio, NULL);
+		if (!swapcache)
+			folio->private = NULL;
+		folio_wait_locked(folio);
+	}
+
+	if (!folio_trylock(folio))
+		goto out_release;
+
+	if (swapcache) {
+		/*
+		 * Make sure folio_free_swap() or swapoff dif not release the
+		 * swapcache from under us. The page pin, and pte_same test
+		 * below, are not enough to exclude that. Even if it is still
+		 * swapcache, we need to check that the page's swap has not changed.
+		 */
+		if (unlikely(!folio_test_swapcache(folio) ||
+					page_swap_entry(&folio->page).val != entry.val)) {
+			goto out_page;
+		}
+	}
+
+	/*
+	 * If we are going to COW a private mapping later, we examine the
+	 * pending reservations for this page now. This will ensure that
+	 * any allocations necessary to record that reservation occur outside
+	 * the spinlock.
+	 */
+	if ((flags & FAULT_FLAG_WRITE) && !(vma->vm_flags & VM_SHARED)) {
+		if (vma_needs_reservation(h, vma, haddr) < 0) {
+			ret = VM_FAULT_OOM;
+			goto out_page;
+		}
+		/* Just decrements count, does not deallocate */
+		vma_end_reservation(h, vma, haddr);
+	}
+
+	ptl = huge_pte_lock(h, mm, ptep);
+	if (unlikely(!ptep || !pte_same(huge_ptep_get(ptep), old_pte)))
+		goto out_nomap;
+
+	if (unlikely(!folio_test_uptodate(folio))) {
+		ret = VM_FAULT_SIGBUS;
+		goto out_nomap;
+	}
+
+	arch_swap_restore(folio_swap(entry, folio), folio);
+
+	swap_free_nr(entry, nr_pages);
+	if (should_try_to_free_swap(folio, vma, flags))
+		folio_free_swap(folio);
+
+	hugetlb_dec_swap_pages(h);
+	hugetlb_count_add(nr_pages, mm);
+	/*
+	 * For a swap-cache hit on an already-anon folio (e.g. another task
+	 * faulted it in first), add a new rmap reference and carry the
+	 * anon-exclusive marker from the swap PTE. Otherwise this is a fresh
+	 * allocation that becomes anon here.
+	 */
+	if (swapcache && folio_test_anon(folio))
+		hugetlb_add_anon_rmap(folio, vma, haddr,
+				      pte_swp_exclusive(old_pte) ? RMAP_EXCLUSIVE : 0);
+	else
+		hugetlb_add_new_anon_rmap(folio, vma, haddr);
+
+	new_pte = make_huge_pte(vma, &folio->page, ((vma->vm_flags & VM_WRITE)
+				&& (vma->vm_flags & VM_SHARED)));
+	if (pte_swp_soft_dirty(old_pte))
+		new_pte = pte_mksoft_dirty(new_pte);
+	if (pte_swp_uffd_wp(old_pte))
+		new_pte = huge_pte_mkuffd_wp(new_pte);
+	set_huge_pte_at(mm, haddr, ptep, new_pte, huge_page_size(h));
+	spin_unlock(ptl);
+	folio_set_hugetlb_migratable(folio);
+	folio_unlock(folio);
+
+out:
+	/* Clear the swap cache pin for direct swapin after PTL unlock */
+	if (need_clear_cache) {
+		swapcache_clear(si, entry, nr_pages);
+		if (waitqueue_active(&swapcache_wq))
+			wake_up(&swapcache_wq);
+	}
+
+	if (si)
+		put_swap_device(si);
+
+	hugetlb_vma_unlock_read(vma);
+	mutex_unlock(&hugetlb_fault_mutex_table[hash]);
+	return ret;
+
+out_nomap:
+	if (ptep)
+		pte_unmap_unlock(ptep, ptl);
+out_page:
+	folio_unlock(folio);
+out_release:
+	folio_put(folio);
+	if (need_clear_cache) {
+		swapcache_clear(si, entry, nr_pages);
+		if (waitqueue_active(&swapcache_wq))
+			wake_up(&swapcache_wq);
+	}
+	if (si)
+		put_swap_device(si);
+
+	hugetlb_vma_unlock_read(vma);
+	mutex_unlock(&hugetlb_fault_mutex_table[hash]);
+	return ret;
+}
+#endif /* CONFIG_HUGETLB_SWAP */
