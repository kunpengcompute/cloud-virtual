+
+bool hugetlb_swap_enabled(void)
+{
+	return READ_ONCE(hugetlb_swap_on);
+}
+
+static int __init parse_hugetlb_swap(char *str)
+{
+	if (!str)
+		return -EINVAL;
+	if (!strcmp(str, "on") || !strcmp(str, "1"))
+		hugetlb_swap_on = true;
+	else if (!strcmp(str, "off") || !strcmp(str, "0"))
+		hugetlb_swap_on = false;
+	else
+		return -EINVAL;
+	return 0;
+}
+early_param("hugetlb_swap", parse_hugetlb_swap);
+#endif
