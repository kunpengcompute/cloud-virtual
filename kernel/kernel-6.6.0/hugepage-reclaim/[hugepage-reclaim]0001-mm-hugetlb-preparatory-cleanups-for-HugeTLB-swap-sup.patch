 			 */
+#ifdef CONFIG_HUGETLB_PMD_PAGE_TABLE_SHARING
+			bool anon = folio_test_anon(folio);
 			if (!anon) {
 				VM_BUG_ON(!(flags & TTU_RMAP_LOCKED));
 				if (!hugetlb_vma_trylock_write(vma))
@@ -1761,6 +1761,7 @@ static bool try_to_unmap_one(struct folio *folio, struct vm_area_struct *vma,
 				}
 				hugetlb_vma_unlock_write(vma);
 			}
+#endif
 			pteval = huge_ptep_clear_flush(vma, address, pvmw.pte);
 		} else {
 			nr_pages = folio_unmap_pte_batch(folio, &pvmw, flags, pteval);
@@ -2098,8 +2099,6 @@ static bool try_to_migrate_one(struct folio *folio, struct vm_area_struct *vma,
 				 PageAnonExclusive(subpage);
 
 		if (folio_test_hugetlb(folio)) {
-			bool anon = folio_test_anon(folio);
-
 			/*
 			 * huge_pmd_unshare may unmap an entire PMD page.
 			 * There is no way of knowing exactly which PMDs may
@@ -2119,6 +2118,8 @@ static bool try_to_migrate_one(struct folio *folio, struct vm_area_struct *vma,
 			 * i_mmap_rwsem.  We can only try lock here and
 			 * fail if unsuccessful.
 			 */
+#ifdef CONFIG_HUGETLB_PMD_PAGE_TABLE_SHARING
+			bool anon = folio_test_anon(folio);
 			if (!anon) {
 				VM_BUG_ON(!(flags & TTU_RMAP_LOCKED));
 				if (!hugetlb_vma_trylock_write(vma)) {
@@ -2140,6 +2141,7 @@ static bool try_to_migrate_one(struct folio *folio, struct vm_area_struct *vma,
 				}
 				hugetlb_vma_unlock_write(vma);
 			}
+#endif
 			/* Nuke the hugetlb page table entry */
 			pteval = huge_ptep_clear_flush(vma, address, pvmw.pte);
 		} else {
