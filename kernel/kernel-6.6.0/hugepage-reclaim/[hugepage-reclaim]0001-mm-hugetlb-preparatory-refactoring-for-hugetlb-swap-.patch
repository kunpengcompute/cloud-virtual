+/*
+ * Check reservation for a private-mapping COW page and end it.
+ * Returns true on success, false if reservation fails (OOM).
+ */
+bool hugetlb_fault_reserve(struct hstate *h, struct vm_area_struct *vma,
+			     unsigned long addr)
+{
+	if (vma_needs_reservation(h, vma, addr) < 0)
+		return false;
+	/* Just decrements count, does not deallocate */
+	vma_end_reservation(h, vma, addr);
+	return true;
