+#define HUGETLB_RECLAIM_BATCH 2
+#define MAX_HUGETLB_RECLAIM_RETRIES 16
+#define HUGETLB_INACTIVE_SCAN_RATIO	3
+
+static inline bool too_many_isolated(struct hstate *h)
+{
+	return READ_ONCE(h->nr_isolated_huge_pages) > (h->nr_huge_pages / 4);	/* 25% */
+}
+
+/*
+ * Hugetlb folio state machine
+ * ---------------------------
+ *
+ * Every hugetlb folio tracked by an hstate is in exactly one of three
+ * states.  The state is encoded in the {HPG_migratable, HPG_isolated,
+ * HPG_inactive} flag bits and the list it lives on:
+ *
+ *   ACTIVE   : on h->hugepage_activelist;
+ *              migratable=1, isolated=0, inactive=0.
+ *              Eligible for migration / compaction.
+ *
+ *   ISOLATED : on a caller-private list (off both hstate lists);
+ *              migratable=0, isolated=1, inactive=0.
+ *              Reached via isolate_hugetlb() or
+ *              __isolate_hugetlb_inactive_locked().
+ *
+ *   INACTIVE : on h->hugepage_inactivelist;
+ *              migratable=0, isolated=0, inactive=1.
+ *              Reached via hugetlb_putback_after_reclaim() when the
+ *              inactive admission policy admits the folio.  Migration
+ *              and compaction skip these because migratable=0.
+ *
+ * Allowed transitions:
+ *
+ *               isolate
+ *      ACTIVE  ───────►  ISOLATED ◄──────┐
+ *         ▲                 │  │         │
+ *         │  putback        │  │ park    │ isolate-from-inactive
+ *         │  (admission     │  │ (policy │
+ *         │   denies)       │  │  admits)│
+ *         └─────────────────┘  ▼         │
+ *                            INACTIVE ───┘
+ *                              │  ▲
+ *                              │  │
+ *                          promote (swap-in)
+ *
+ * State mutation is performed exclusively by the __locked helpers
+ * below; each one lockdep_assert_held(&hugetlb_lock).  Public APIs are
+ * thin wrappers that take the lock and dispatch.  Counters
+ * (nr_inactive_huge_pages) are maintained inside the same critical
+ * section as the list moves, so they cannot drift from the list length.
+ *
+ * The inactive list is FIFO: insertion uses list_add_tail(), drain
+ * scans from the head.  Head = oldest = next victim.
+ */
+
+static void __hugetlb_putback_active_locked(struct folio *folio,
+					    struct hstate *h)
+{
+	lockdep_assert_held(&hugetlb_lock);
+	folio_clear_hugetlb_isolated(folio);
+	folio_set_hugetlb_migratable(folio);
+	list_move(&folio->lru, &h->hugepage_activelist);
+	if (!WARN_ON_ONCE(h->nr_isolated_huge_pages == 0))
+		h->nr_isolated_huge_pages--;
+}
+
+static void __hugetlb_park_inactive_locked(struct folio *folio,
+					   struct hstate *h)
+{
+	lockdep_assert_held(&hugetlb_lock);
+	WARN_ON_ONCE(folio_test_hugetlb_inactive(folio));
+	folio_clear_hugetlb_isolated(folio);
+	folio_clear_hugetlb_migratable(folio);
+	folio_set_hugetlb_inactive(folio);
+	h->nr_inactive_huge_pages++;
+	list_move(&folio->lru, &h->hugepage_inactivelist);
+	if (!WARN_ON_ONCE(h->nr_isolated_huge_pages == 0))
+		h->nr_isolated_huge_pages--;
+}
+
+static void __hugetlb_promote_active_locked(struct folio *folio,
+					    struct hstate *h)
+{
+	lockdep_assert_held(&hugetlb_lock);
+	WARN_ON_ONCE(!folio_test_hugetlb_inactive(folio));
+	folio_clear_hugetlb_inactive(folio);
+	folio_set_hugetlb_migratable(folio);
+	list_move(&folio->lru, &h->hugepage_activelist);
+	if (WARN_ON_ONCE(h->nr_inactive_huge_pages == 0))
+		return;
+	h->nr_inactive_huge_pages--;
+}
+
+/*
+ * Inactive admission rule.
+ */
+static bool hugetlb_inactive_admits_locked(struct folio *folio)
+{
+	lockdep_assert_held(&hugetlb_lock);
+	return folio_test_swapcache(folio) && !folio_mapped(folio);
+}
+
+/*
+ * hugetlb_putback_after_reclaim - the single putback called by the page
+ * reclaim shrinker after shrink_folio_list() returns a hugetlb folio.
+ *
+ * The folio is in the ISOLATED state (HPG_isolated set, on the caller's
+ * private list which has already been unlinked).  Under one hugetlb_lock
+ * critical section we consult the inactive admission policy and route to
+ * either INACTIVE (policy admits) or ACTIVE (policy denies).  This is the
+ * only path that consumes the inactive admission policy, so all callers
+ * see consistent routing.
+ *
+ * Drops the caller's reference.
+ */
 void hugetlb_putback_after_reclaim(struct folio *folio)
 {
-	folio_putback_active_hugetlb(folio);
+	struct hstate *h;
+
+	if (WARN_ON_ONCE(!folio_test_hugetlb(folio))) {
+		folio_put(folio);
+		return;
+	}
+
+	h = folio_hstate(folio);
+
+	spin_lock_irq(&hugetlb_lock);
+	if (hugetlb_inactive_admits_locked(folio))
+		__hugetlb_park_inactive_locked(folio, h);
+	else
+		__hugetlb_putback_active_locked(folio, h);
+	spin_unlock_irq(&hugetlb_lock);
+
+	folio_put(folio);
+}
+
+/*
+ * hugetlb_promote_to_active - move a folio off the inactive list back
+ * onto the active list.
+ *
+ * Called from the swap-in / fault-in paths after a folio has been pulled
+ * out of the swap cache and is about to be remapped or re-attached to a
+ * page cache.  Idempotent: if the folio is not currently HPG_inactive,
+ * this is a no-op so call sites can invoke it unconditionally.
+ */
+void hugetlb_promote_to_active(struct folio *folio)
+{
+	struct hstate *h;
+
+	spin_lock_irq(&hugetlb_lock);
+	if (folio_test_hugetlb_isolated(folio) || !folio_test_hugetlb_inactive(folio)) {
+		spin_unlock_irq(&hugetlb_lock);
+		return;
+	}
+
+	h = folio_hstate(folio);
+	__hugetlb_promote_active_locked(folio, h);
+	spin_unlock_irq(&hugetlb_lock);
+}
+
+/*
+ * Isolate a folio from the inactive list (INACTIVE -> ISOLATED).  Both
+ * the list move and the per-hstate counter decrement happen inside the
+ * caller's hugetlb_lock critical section, keeping the counter and list
+ * length in lockstep.
+ */
+static bool __isolate_hugetlb_inactive_locked(struct folio *folio,
+					      struct hstate *h,
+					      struct list_head *list)
+{
+	lockdep_assert_held(&hugetlb_lock);
+
+	WARN_ON_ONCE(!folio_test_hugetlb_inactive(folio));
+	if (!folio_test_hugetlb(folio) ||
+	    !folio_test_hugetlb_inactive(folio) ||
+	    folio_test_hugetlb_isolated(folio) ||
+	    !folio_try_get(folio))
+		return false;
+
+	folio_set_hugetlb_isolated(folio);
+	list_move_tail(&folio->lru, list);
+	h->nr_isolated_huge_pages++;
+	folio_clear_hugetlb_inactive(folio);
+	if (WARN_ON_ONCE(h->nr_inactive_huge_pages == 0))
+		return true;
+	h->nr_inactive_huge_pages--;
+	return true;
+}
+
+unsigned long hugetlb_reclaim_inactive_folios(struct hstate *h,
+					      unsigned long nr_to_reclaim,
+					      const nodemask_t *allowed)
+{
+	LIST_HEAD(pagelist);
+	struct folio *folio, *next;
+	unsigned long isolated = 0;
+	unsigned long nr_reclaimed = 0;
+	unsigned long nr_to_scan = nr_to_reclaim * HUGETLB_INACTIVE_SCAN_RATIO;
+
+	if (!h)
+		return 0;
+
+	cond_resched();
+
+	spin_lock_irq(&hugetlb_lock);
+	list_for_each_entry_safe_reverse(folio, next,
+				 &h->hugepage_inactivelist, lru) {
+		/*
+		 * Only reclaim folios on nodes the faulting allocation can
+		 * actually consume on retry (e.g. an MPOL_BIND nodemask):
+		 * freeing a folio on any other node does not relieve the
+		 * pressure that triggered direct reclaim.  A NULL mask means
+		 * no node restriction (default policy / proactive trigger).
+		 */
+		if (allowed && !node_isset(folio_nid(folio), *allowed))
+			continue;
+		if (__isolate_hugetlb_inactive_locked(folio, h, &pagelist))
+			isolated++;
+		if (isolated >= nr_to_scan)
+			break;
+	}
+	spin_unlock_irq(&hugetlb_lock);
+
+	if (!isolated)
+		return 0;
+
+	nr_reclaimed = reclaim_pages(&pagelist, true) >> huge_page_order(h);
+	return nr_reclaimed;
+}
+
+void folio_rotate_hugetlb_to_tail(struct folio *folio)
+{
+	unsigned long flags;
+
+	spin_lock_irqsave(&hugetlb_lock, flags);
+	if (folio_test_hugetlb_isolated(folio)) {
+		spin_unlock_irqrestore(&hugetlb_lock, flags);
+		return;
+	}
+
+	if (folio_test_hugetlb_inactive(folio))
+		list_move_tail(&folio->lru, &(folio_hstate(folio))->hugepage_inactivelist);
+	else
+		list_move_tail(&folio->lru, &(folio_hstate(folio))->hugepage_activelist);
+	spin_unlock_irqrestore(&hugetlb_lock, flags);
+}
+
+/*
+ * Wait while too many hugetlb folios are isolated pool-wide.  Shared by
+ * the fault-path direct reclaimer (interruptible=false) and the proactive
+ * reclaim_inactive sysfs trigger (interruptible=true, so a userspace
+ * writer blocked on the gate can be cancelled with SIGINT).
+ *
+ * Returns 0 to proceed, -EINTR if a signal cancelled the wait.
+ */
+static int hugetlb_reclaim_throttle(struct hstate *h, bool interruptible)
+{
+	long state = interruptible ? TASK_INTERRUPTIBLE : TASK_UNINTERRUPTIBLE;
+
+	while (too_many_isolated(h)) {
+		DEFINE_WAIT(wait);
+		wait_queue_head_t *wqh = &h->reclaim_wait;
+
+		/*
+		 * Re-test the gate after joining the wait queue so a wake-up
+		 * from hugetlb_dec_nr_isolated() racing the check above is not
+		 * lost.  The timeout is a safety net, not the wake-up source.
+		 */
+		prepare_to_wait(wqh, &wait, state);
+		if (too_many_isolated(h))
+			schedule_timeout(HZ / 50);	/* 20ms cap */
+		finish_wait(wqh, &wait);
+
+		if (interruptible && signal_pending(current))
+			return -EINTR;
+		if (fatal_signal_pending(current))
+			return -EINTR;
+	}
+	return 0;
+}
+
+static unsigned long reclaim_hugetlb_folios(struct hstate *h,
+					    unsigned long nr_to_scan,
+					    const nodemask_t *allowed)
+{
+	unsigned long isolated = 0;
+	struct folio *folio, *next;
+	unsigned long nr_reclaimed = 0;
+	LIST_HEAD(pagelist);
+
+	cond_resched();
+
+	if (hugetlb_reclaim_throttle(h, false))
+		return 0;
+
+	/*
+	 * Drain the inactive list first: these folios have already been
+	 * add_to_swap + try_to_unmap + pageout'd, so all we need is to
+	 * drop the swap cache reference and free the page.  This is much
+	 * cheaper than scanning the active list.
+	 */
+	nr_reclaimed = hugetlb_reclaim_inactive_folios(h, nr_to_scan, allowed);
+	if (nr_reclaimed >= nr_to_scan)
+		return nr_reclaimed;
+	nr_to_scan -= nr_reclaimed;
+
+	/*
+	 * Fall back to the active list for the remaining pages.
+	 * This is the expensive path: add_to_swap, try_to_unmap, pageout.
+	 */
+	spin_lock_irq(&hugetlb_lock);
+	list_for_each_entry_safe_reverse(folio, next, &h->hugepage_activelist, lru) {
+		/* See the node filter in hugetlb_reclaim_inactive_folios(). */
+		if (allowed && !node_isset(folio_nid(folio), *allowed))
+			continue;
+		if (folio_ref_count(folio) && __isolate_hugetlb_locked(folio, &pagelist))
+			isolated++;
+
+		if (isolated >= nr_to_scan)
+			break;
+	}
+	spin_unlock_irq(&hugetlb_lock);
+
+	if (!isolated)
+		return nr_reclaimed;
+
+	nr_reclaimed += reclaim_pages(&pagelist, true) >> huge_page_order(h);
+	return nr_reclaimed;
+}
+
+static unsigned long perform_hugetlb_folio_reclaim(struct hstate *h,
+						   unsigned long nr_to_reclaim,
+						   const nodemask_t *allowed)
+{
+	unsigned long total_pages = h->nr_huge_pages - h->free_huge_pages -
+				    READ_ONCE(h->nr_isolated_huge_pages);
+	unsigned long nr_reclaimed = 0;
+	struct blk_plug plug;
+
+	blk_start_plug(&plug);
+	while (total_pages && nr_reclaimed < nr_to_reclaim) {
+		unsigned long nr_to_scan = min_t(unsigned long, total_pages,
+						 HUGETLB_RECLAIM_BATCH);
+
+		total_pages -= nr_to_scan;
+		nr_reclaimed += reclaim_hugetlb_folios(h, nr_to_scan, allowed);
+		cond_resched();
+	}
+	blk_finish_plug(&plug);
+	return nr_reclaimed;
+}
+
+bool hugetlb_folio_direct_reclaim(struct vm_area_struct *vma, unsigned long addr)
+{
+	int loops = 0;
+	unsigned long nr_reclaimed;
+	struct hstate *h = hstate_vma(vma);
+	const nodemask_t *allowed = NULL;
+	struct mempolicy *mpol;
+	nodemask_t *nodemask;
+	bool node_restricted;
+	gfp_t gfp_mask;
+
+	if (!h || hstate_is_gigantic(h))
+		return false;
+
+	/*
+	 * Mirror dequeue_hugetlb_folio_vma()'s node selection so we only
+	 * reclaim folios the retried allocation can actually consume:
+	 * freeing a hugepage on a node outside the fault's mempolicy does
+	 * not relieve the pressure that triggered direct reclaim.  Only a
+	 * strict MPOL_BIND nodemask restricts placement; default, preferred
+	 * and preferred-many policies fall back to the full zonelist on
+	 * retry and therefore impose no restriction (allowed stays NULL,
+	 * preserving the original cross-node behaviour).  vma and the
+	 * mempolicy are stable here: callers still hold mmap_read_lock.
+	 */
+	gfp_mask = htlb_alloc_mask(h);
+	huge_node(vma, addr, gfp_mask, &mpol, &nodemask);
+	if (nodemask && !mpol_is_preferred_many(mpol))
+		allowed = nodemask;
+	node_restricted = allowed != NULL;
+
+retry:
+	nr_reclaimed = perform_hugetlb_folio_reclaim(h, HUGETLB_RECLAIM_BATCH,
+						     allowed);
+	if (nr_reclaimed) {
+		mpol_cond_put(mpol);
+		return true;
+	}
+
+	/*
+	 * With a binding nodemask, a zero-progress pass means the target
+	 * nodes have nothing reclaimable -- the entire node-filtered list
+	 * was already scanned, so retrying just repeats identical work.
+	 * Fail fast to OOM/SIGBUS instead of spinning
+	 * MAX_HUGETLB_RECLAIM_RETRIES times.  Unrestricted callers keep
+	 * retrying to absorb transient races with concurrent isolators.
+	 */
+	if (!node_restricted && loops++ < MAX_HUGETLB_RECLAIM_RETRIES)
+		goto retry;
+
+	mpol_cond_put(mpol);
+	return false;
 }
 #endif /* CONFIG_HUGETLB_SWAP */
