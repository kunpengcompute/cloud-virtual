@@ -6292,10 +6295,23 @@ bool hugetlbfs_pagecache_present(struct hstate *h,
 	struct folio *folio;
 
 	folio = filemap_get_folio(mapping, idx);
-	if (IS_ERR(folio))
-		return false;
-	folio_put(folio);
-	return true;
