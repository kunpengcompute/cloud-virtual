+/*
+ * Remove swap entry from page cache, free the swap and its page cache.
+ * Returns the number of HugeTLB pages freed. 0 means entry not found in
+ * the XArray (0 pages being freed).
+ */
+long hugetlbfs_free_swap(struct address_space *mapping, pgoff_t index,
+			 void *radswap, struct hstate *h)
+{
+	XA_STATE_ORDER(xas, &mapping->i_pages, index, huge_page_order(h));
+	swp_entry_t entry = radix_to_swp_entry(radswap);
+	struct swap_info_struct *si;
+	struct folio *folio;
+	void *old;
+
+	xas_lock_irq(&xas);
+	old = xas_load(&xas);
+	if (old != radswap) {
+		xas_unlock_irq(&xas);
+		return 0;
+	}
+	xas_store(&xas, NULL);
+	xas_unlock_irq(&xas);
+
+	free_swap_and_cache_nr(entry, pages_per_huge_page(h));
+
+	si = get_swap_device(entry);
+	if (si) {
+		folio = filemap_get_folio(swap_address_space(entry),
+					  swp_offset(entry));
+		if (!IS_ERR(folio)) {
+			folio_lock(folio);
+			folio_wait_writeback(folio);
+			if (folio_test_swapcache(folio))
+				delete_from_swap_cache(folio);
+			folio_unlock(folio);
+			folio_put(folio);
+		}
+		put_swap_device(si);
+	}
+
+	hugetlb_dec_swap_pages(h);
+	return 1;
+}
