diff --git a/mm/filemap.c b/mm/filemap.c
index 246ccb845605..308f513fa139 100644
--- a/mm/filemap.c
+++ b/mm/filemap.c
@@ -20,6 +20,7 @@
 #include <linux/kernel_stat.h>
 #include <linux/gfp.h>
 #include <linux/mm.h>
+#include <linux/swap_slots.h>
 #include <linux/swap.h>
 #include <linux/swapops.h>
 #include <linux/syscalls.h>
@@ -857,7 +858,16 @@ noinline int __filemap_add_folio(struct address_space *mapping,
 	unsigned int forder = folio_order(folio);
 
 	VM_BUG_ON_FOLIO(!folio_test_locked(folio), folio);
-	VM_BUG_ON_FOLIO(folio_test_swapbacked(folio), folio);
+#ifdef CONFIG_HUGETLB_SWAP
+	/*
+	 * When CONFIG_HUGETLB_SWAP is enabled, hugetlb folios are
+	 * allowed to be added to the page cache, and they can be
+	 * both swap-backed and file-backed.
+	 */
+	if (!folio_test_hugetlb(folio))
+#endif
+		VM_BUG_ON_FOLIO(folio_test_swapbacked(folio), folio);
+
 	mapping_set_update(&xas, mapping);
 
 	VM_BUG_ON_FOLIO(index & (folio_nr_pages(folio) - 1), folio);
@@ -2146,6 +2156,41 @@ unsigned find_lock_entries(struct address_space *mapping, pgoff_t *start,
 	return folio_batch_count(fbatch);
 }
 
+unsigned filemap_get_hugepages(struct address_space *mapping, pgoff_t *start,
+		pgoff_t end, struct folio_batch *fbatch, pgoff_t *indices)
+{
+	struct inode *inode = mapping->host;
+	struct hstate *h = hstate_inode(inode);
+	XA_STATE(xas, &mapping->i_pages, *start);
+	struct folio *folio;
+
+	rcu_read_lock();
+	while ((folio = find_get_entry(&xas, end, XA_PRESENT)) != NULL) {
+		indices[fbatch->nr] = xas.xa_index;
+		if (!folio_batch_add(fbatch, folio)) {
+			int idx = folio_batch_count(fbatch) - 1;
+			unsigned long nr = pages_per_huge_page(h);
+			*start = indices[idx] + nr;
+			goto out;
+		}
+	}
+
+	/*
+	 * We come here when there is no page beyond @end. We take care to not
+	 * overflow the index @start as it confuses some of the callers. This
+	 * breaks the iteration when there is a page at index -1 but that is
+	 * already broken anyway.
+	 */
+	if (end == (pgoff_t)-1)
+		*start = (pgoff_t)-1;
+	else
+		*start = end + 1;
+out:
+	rcu_read_unlock();
+
+	return folio_batch_count(fbatch);
+}
+
 /**
  * filemap_get_folios - Get a batch of folios
  * @mapping:	The address_space to search
