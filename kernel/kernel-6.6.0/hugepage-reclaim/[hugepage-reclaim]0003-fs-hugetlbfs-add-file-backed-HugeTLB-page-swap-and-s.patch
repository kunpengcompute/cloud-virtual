 }
 
 static int __hugetlb_add_to_page_cache(struct folio *folio,
@@ -6390,6 +6406,183 @@ static bool hugetlb_pte_stable(struct hstate *h, struct mm_struct *mm,
 	return same;
 }
 
+#ifdef CONFIG_HUGETLB_SWAP
+static struct folio *hugetlbfs_swap_alloc_folio(struct vm_area_struct *vma,
+								struct hstate *h, unsigned long haddr,
+								swp_entry_t entry)
+{
+	struct swap_info_struct *si;
+	struct folio *new;
+
+	if (vma) {
+		new = alloc_hugetlb_folio(vma, haddr, 1);
+	} else {
+		gfp_t gfp_mask = htlb_alloc_mask(h);
+		int nid = numa_node_id();
+		new = alloc_hugetlb_folio_nodemask(h, nid, NULL, gfp_mask);
+	}
+
+	if (IS_ERR(new))
+		return new;
+
+	if (swapcache_prepare(entry, pages_per_huge_page(h))) {
+		folio_put(new);
+		return ERR_PTR(-EEXIST);
+	}
+
+	__folio_set_locked(new);
+	__folio_set_swapbacked(new);
+	new->swap = entry;
+
+	si = swp_swap_info(entry);
+	if (!data_race(si->flags & SWP_SYNCHRONOUS_IO)) {
+		if (WARN_ON_ONCE(add_to_swap_cache(new, entry,
+			GFP_KERNEL, NULL))) {
+			goto fail_unlock;
+		}
+	}
+
+	swap_read_folio(new, NULL);
+	return new;
+
+fail_unlock:
+	put_swap_folio(new, entry);
+	folio_unlock(new);
+	folio_put(new);
+	return ERR_PTR(-ENOMEM);
+}
+
+static struct folio *hugetlbfs_do_swapin(struct address_space *mapping,
+		       pgoff_t index, swp_entry_t entry,
+		       struct vm_area_struct *vma, struct hstate *h,
+		       unsigned long haddr)
+{
+	struct swap_info_struct *si;
+	struct folio *folio;
+	struct inode *inode = mapping->host;
+	bool skip_swapcache = false;
+	int error;
+
+	si = get_swap_device(entry);
+	if (!si)
+		return ERR_PTR(-EINVAL);
+
+	folio = swap_cache_get_folio(entry, NULL, 0);
+	if (!folio) {
+		folio = hugetlbfs_swap_alloc_folio(vma, h, haddr, entry);
+		if (IS_ERR(folio)) {
+			put_swap_device(si);
+			return folio;
+		}
+		/*
+		 * hugetlbfs_swap_alloc_folio() only bypasses the swap cache
+		 * on the SWP_SYNCHRONOUS_IO path; the async path still calls
+		 * add_to_swap_cache() before returning.
+		 */
+		if (data_race(si->flags & SWP_SYNCHRONOUS_IO))
+			skip_swapcache = true;
+	}
+
+	folio_lock(folio);
+
+	folio_wait_writeback(folio);
+
+	if (!folio_test_uptodate(folio)) {
+		error = -EIO;
+		goto failed_unlock;
+	}
+
+	arch_swap_restore(folio_swap(entry, folio), folio);
+
+	error = __hugetlb_add_to_page_cache(folio, mapping, index);
+	if (error)
+		goto failed_unlock;
+
+	mutex_lock(&hugetlbfs_swaplist_mutex);
+	if (atomic_sub_return(pages_per_huge_page(h),
+		&HUGETLBFS_I(inode)->swapped) == 0)
+		list_del_init(&HUGETLBFS_I(inode)->swaplist);
+	mutex_unlock(&hugetlbfs_swaplist_mutex);
+
+	hugetlb_dec_swap_pages(h);
+
+	/*
+	 * Drop the swap cache entry after the folio is in the page cache,
+	 * mirroring shmem_swapin_folio(). __filemap_add_folio() permits
+	 * swapbacked hugetlb folios, and delete_from_swap_cache() keys off
+	 * folio->swap rather than folio->mapping.
+	 */
+	if (skip_swapcache) {
+		folio->swap.val = 0;
+		swapcache_clear(si, entry, pages_per_huge_page(h));
+	} else {
+		delete_from_swap_cache(folio);
+	}
+
+	folio_mark_dirty(folio);
+	swap_free_nr(entry, pages_per_huge_page(h));
+	put_swap_device(si);
+	folio_set_hugetlb_migratable(folio);
+
+	return folio;
+
+failed_unlock:
+	if (skip_swapcache) {
+		folio->swap.val = 0;
+		swapcache_clear(si, entry, pages_per_huge_page(h));
+	}
+	folio_unlock(folio);
+	folio_put(folio);
+	put_swap_device(si);
+	return ERR_PTR(error);
+}
