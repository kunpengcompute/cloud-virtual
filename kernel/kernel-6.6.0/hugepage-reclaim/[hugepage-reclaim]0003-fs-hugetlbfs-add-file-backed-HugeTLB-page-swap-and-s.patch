+int hugetlbfs_writepage(struct page *page, struct writeback_control *wbc)
+{
+	struct folio *folio = page_folio(page);
+	struct address_space *mapping = folio->mapping;
+	struct inode *inode = mapping->host;
+	struct hugetlbfs_inode_info *info = HUGETLBFS_I(inode);
+	swp_entry_t swap;
+	int nr_pages = folio_nr_pages(folio);
+
+	swap = folio_alloc_swap_huge(folio);
+	if (!swap.val)
+		goto redirty;
+
+	/*
+	 * Add inode to hugetlbfs_unuse()'s list of swapped-out inodes,
+	 * if it's not already there. Do this before adding to swap cache.
+	 */
+	mutex_lock(&hugetlbfs_swaplist_mutex);
+	if (list_empty(&info->swaplist))
+		list_add(&info->swaplist, &hugetlbfs_swaplist);
+
+	if (add_to_swap_cache(folio, swap,
+			__GFP_HIGH | __GFP_NOMEMALLOC | __GFP_NOWARN,
+			NULL) != 0) {
+		goto put_swap;
+	}
+	atomic_add(nr_pages, &info->swapped);
+	swap_shmem_alloc(swap, nr_pages);
+	hugetlb_delete_from_page_cache(folio, swp_to_radix_entry(swap));
+	hugetlb_inc_swap_pages(folio_hstate(folio));
+	mutex_unlock(&hugetlbfs_swaplist_mutex);
+	return swap_writepage(&folio->page, wbc);
+
+put_swap:
+	/*
+	 * If the folio was added to swap cache (via add_to_swap_cache), we need
+	 * to delete it from swap cache. Otherwise, just put the swap slot.
+	 */
+	if (folio_test_swapcache(folio))
+		delete_from_swap_cache(folio);
+	else
+		put_swap_folio(folio, swap);
+	mutex_unlock(&hugetlbfs_swaplist_mutex);
+redirty:
+	folio_redirty_for_writepage(wbc, folio);
+	if (wbc->for_reclaim)
+		return AOP_WRITEPAGE_ACTIVATE;	/* Return with folio locked */
+	folio_unlock(folio);
+	return 0;
+}
