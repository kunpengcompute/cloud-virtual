+/*
+ * hugetlbfs_unuse_swapin - swapin a hugetlbfs page for swapoff
+ * Called from fs/hugetlbfs/inode.c:hugetlbfs_unuse_inode()
+ * This is similar to hugetlbfs_do_swapin() but works without a VMA.
+ */
+int hugetlbfs_unuse_swapin(struct inode *inode, pgoff_t index, swp_entry_t entry)
+{
+	struct address_space *mapping = inode->i_mapping;
+	struct hstate *h = hstate_inode(inode);
+	struct folio *folio;
+
+	folio = hugetlbfs_do_swapin(mapping, index, entry, NULL, h, 0);
+	if (IS_ERR(folio))
+		return PTR_ERR(folio);
+
+	folio_unlock(folio);
+	folio_put(folio);
+	return 0;
+}
+
+static struct folio *hugetlb_no_page_swapin(struct mm_struct *mm,
+		struct vm_area_struct *vma, struct address_space *mapping,
+		pgoff_t idx, pte_t *ptep, pte_t old_pte, unsigned long haddr)
+{
+	struct hstate *h = hstate_vma(vma);
+	struct folio *folio;
+	swp_entry_t entry;
+	void *xa_val;
+
+	xa_val = xa_load(&mapping->i_pages, idx << huge_page_order(h));
+	if (!xa_is_value(xa_val))
+		return ERR_PTR(-ENOENT);
+	entry = radix_to_swp_entry(xa_val);
+	if (non_swap_entry(entry))
+		return ERR_PTR(-ENOENT);
+
+	if (!hugetlb_pte_stable(h, mm, ptep, old_pte))
+		return ERR_PTR(-EAGAIN);
+
+	folio = hugetlbfs_do_swapin(mapping, idx, entry, vma, h, haddr);
+	if (IS_ERR(folio) && PTR_ERR(folio) == -EEXIST)
+		return ERR_PTR(-EAGAIN);	/* concurrent swapin race */
+	return folio;
+}
