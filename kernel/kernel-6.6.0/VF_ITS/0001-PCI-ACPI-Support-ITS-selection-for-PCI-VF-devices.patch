 drivers/pci/probe.c                    |   6 +-
 include/linux/acpi_iort.h              |  12 +
 include/linux/irqchip/arm-gic-v3-its.h |  18 ++
 include/linux/pci.h                    |   7 +
 8 files changed, 608 insertions(+), 1 deletion(-)
